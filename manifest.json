{
  "manifest_version": 2,
  "name": "Extensão Privacidade",
  "version": "0.1",
  "description": "Detecta ameaças à privacidade e rastreamento em tempo real.",

  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "extension@insper.edu.br",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [],
        "optional": []
      }
    }
  },

  "permissions": [
    "webRequest",
    "webRequestBlocking",
    "cookies",
    "storage",
    "tabs",
    "privacy",
    "<all_urls>"
  ],

  "background": {
    "scripts": ["extension.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],

  "browser_action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "48": "icons/icon-48.png"
    },
    "default_title": "Privacy Extension"
  },

  "web_accessible_resources": ["content_script.js"]
}